{
  "_meta": {
    "version": 1,
    "description": "ViralPX Theme Registry. Add a new theme by appending an object to `themes`. No core code changes required. Each theme maps its structured config to the existing style_* engine via `legacy_map`, so the current renderer understands it for free.",
    "schema": {
      "id": "unique string id (used as data-theme)",
      "name": "{ en, ar } display names",
      "tokens": "design tokens applied as CSS variables (--accent, --bg, --radius, ...)",
      "components": "component variant choices (button, card, navbar)",
      "layout": "layout preset choices per section (hero, projects, about, contact)",
      "anim": "entrance animation preset",
      "legacy_map": "maps this theme to existing style_* settings keys for backward-compatible rendering"
    }
  },
  "tokens_defaults": {
    "accent": "#6366f1",
    "accent2": "",
    "bg": "#0a0a0a",
    "bg2": "#111111",
    "text": "#ffffff",
    "subtext": "#999999",
    "radius": "12px",
    "radius_sm": "8px",
    "radius_lg": "20px",
    "space": "16px",
    "font_pair": "default"
  },
  "component_variants": {
    "button": [
      "rounded",
      "sharp",
      "pill"
    ],
    "card": [
      "solid",
      "glass",
      "outline"
    ],
    "navbar": [
      "blur",
      "solid",
      "transparent"
    ]
  },
  "layout_presets": {
    "hero": [
      "centered",
      "split",
      "massive",
      "cover-full",
      "minimal"
    ],
    "projects": [
      "grid",
      "masonry",
      "list",
      "freegrid"
    ],
    "about": [
      "classic",
      "visual",
      "simple"
    ],
    "contact": [
      "classic",
      "split"
    ]
  },
